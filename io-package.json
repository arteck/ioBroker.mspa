      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "indicator.connected",
        "name": "If connected",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "info.lastUpdate",
      "type": "state",
      "common": {
        "role": "value.time",
        "name": "Last update time",
        "type": "number",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    }
  ]
